# ============================================================
# SajiloKhata Environment Template
# Copy this file to .env and replace values.
# ============================================================

# ----------------------------
# App Server
# ----------------------------
NODE_ENV=development
PORT=5000

# ----------------------------
# Database (Required)
# ----------------------------
# Local MySQL example:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_local_mysql_password
# DB_NAME=sajilokhata_db

# Cloud MySQL/TiDB example:
# DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
# DB_PORT=4000
# DB_USER=xxxxxxxx.root
# DB_PASSWORD=your_cloud_db_password
# DB_NAME=sajilokhata_db

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=sajilokhata_db

# ----------------------------
# Database SSL/TLS (Optional)
# ----------------------------
# Set DB_SSL=true for cloud databases that require TLS.
# If your provider gives a CA certificate file, set DB_SSL_CA_PATH.
# For some cloud providers, DB_SSL=true with no CA path still works.

DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=

# ----------------------------
# Auth + CORS
# ----------------------------
JWT_SECRET=replace_with_a_long_random_secret
# Local example: http://localhost:5000
# Vercel example: https://your-app-name.vercel.app
CORS_ORIGIN=http://localhost:5000

# ----------------------------
# Backup (Local VM/server only)
# ----------------------------
# On Vercel/serverless set ENABLE_DAILY_BACKUP=false
ENABLE_DAILY_BACKUP=true
BACKUP_INTERVAL_HOURS=24
MYSQLDUMP_PATH=mysqldump
